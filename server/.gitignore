# Dependencies
node_modules/

# Local environment variables containing credentials (JWT secrets, MongoDB URI, Groq/OpenRouter keys)
.env
.env.local
.env.development.local
.env.production.local
.env.test.local

# Allow committing the template example file
!.env.example

# Local uploads and storage folder (since Render/Vercel are ephemeral, uploads should not be tracked)
uploads/
storage/

# Temporary files and logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
temp/
tmp/

# Testing and coverage
coverage/
.nyc_output/

# IDE files
.vscode/
.idea/

# Cache and compiler files
.eslintcache
.cache/
